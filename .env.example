# KidsClubPlans Environment Variables
# Copy this file to .env and fill in your actual API keys

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (GPT-4o, Embeddings)
OPENAI_API_KEY=sk-...

# Moonshot AI (Kimi K2.5)
# Get from: https://platform.moonshot.cn/(or https://api.kimi.com for Kimi For Coding)
KIMI_API_KEY=sk-...

# DeepSeek
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# Pinecone (Vector DB)
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=kidsclubplans

# Optional: For development
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Optional: Override Kimi base URL (default: https://api.moonshot.cn/v1)
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
